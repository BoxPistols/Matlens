# Matlens — 環境変数テンプレート
# このファイルを .env.local にコピーして実際のキーを設定してください
#   cp .env.example .env.local
#
# .env.local は .gitignore で除外されているため、キーがリポジトリに入ることはありません。

# OpenAI API Key（必須: デフォルトプロバイダー nano/mini で使用）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key（任意: プロバイダーを Gemini に切り替えた場合に使用）
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Upstash Vector（任意: サーバーサイドベクトル検索に使用）
# Vercel Marketplace からプロビジョニングすると自動設定されます
UPSTASH_VECTOR_REST_URL=https://xxx.upstash.io
UPSTASH_VECTOR_REST_TOKEN=xxx

# Upstash Redis（任意: レート制限の永続化に使用）
# 未設定の場合は in-memory Map（warm instance ごと）にフォールバック
# Vercel Marketplace から Upstash Redis をプロビジョニングすると自動設定されます
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# 日次レート制限（サーバープロキシ経由の呼び出し回数 / IP / 日）
DAILY_LIMIT=30

# -----------------------------------------------------------------------------
# Matlens PoC: バックエンド抽象化層（Repository）の切替
# -----------------------------------------------------------------------------
# VITE_BACKEND_MODE: mock | rest | graphql
#   mock   — 同梱のメモリ内DBを使用（Phase 1）
#   rest   — Vercel Functions / 本番API 連携（Phase 2以降）
#   graphql — 予約（未実装）
VITE_BACKEND_MODE=mock

# VITE_MSW_ENABLED: true | false
#   true にすると、ブラウザで Service Worker を使って /api/v1/* を
#   モックハンドラに振り分けます。mode=rest へ切替える前の動作確認用。
VITE_MSW_ENABLED=false

# VITE_API_BASE_URL: REST 接続時のベースURL（例: /api/v1 もしくは絶対URL）
# VITE_API_BASE_URL=/api/v1
