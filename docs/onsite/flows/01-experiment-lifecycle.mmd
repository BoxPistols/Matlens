%% 受託試験案件のライフサイクル（叩き台）
%% Source: docs/onsite/personas-workflows.md の 3 ペルソナ仮説
flowchart TD
    A[顧客から相談] --> B{案件成立?}
    B -- 不成立 --> A
    B -- 成立 --> C[PM: 試験計画立案<br/>規格選定 / 試験種別 / 納期]
    C --> D[研究員: 試験条件の詳細設計<br/>材料 × 試験法 × 雰囲気]
    D --> E[技師: 受入試験片の検品<br/>切り出し / 研磨 / 寸法測定]
    E --> F{受入合格?}
    F -- 不合格 --> E1[再加工 or 返却]
    E1 --> E
    F -- 合格 --> G[技師: 試験実施<br/>連続バッチ 3-5 件]
    G --> H{異常所見?}
    H -- あり --> I[研究員 + PM: 検討会<br/>原因分析 / 条件変更]
    I --> J{再試験?}
    J -- する --> G
    J -- しない --> K[結果データ整備<br/>provenance / 単位 / 校正日]
    H -- なし --> K
    K --> L[研究員: 結果解釈 + 考察]
    L --> M[PM: レポート最終レビュー]
    M --> N{承認?}
    N -- 差戻し --> L
    N -- 承認 --> O[顧客へ提出<br/>PDF / MaiML / 別形式]
    O --> P[案件 close + アーカイブ]

    %% Matlens の介在余地ハイライト
    classDef matlens fill:#d3f9d8,stroke:#2b8a3e,stroke-width:2px;
    class C,D,K,L,M matlens;

    %% 凡例
    subgraph LEGEND[凡例]
        Z1[通常ステップ]
        Z2[Matlens 介在候補]:::matlens
    end
