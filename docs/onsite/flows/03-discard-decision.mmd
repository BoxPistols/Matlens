%% 試験片の廃棄判定（保管延長 / 廃棄）
%% Specimen Tracker の状態遷移と接続
flowchart LR
    A[試験済 specimen] --> B{追加分析の<br/>可能性?}
    B -- あり --> C[保管棚へ]
    B -- なし --> D{顧客契約上の<br/>保管義務?}
    D -- あり --> C
    D -- なし --> E{ITAR / EAR<br/>該当?}
    E -- 該当 --> F[管理廃棄<br/>記録必須]
    E -- 非該当 --> G{再資源化可能<br/>材料?}
    G -- 可能 --> H[リサイクル業者]
    G -- 不可 --> I[通常廃棄]

    C --> C1[6 ヶ月後再判定]
    C1 --> B

    %% 仮説: 廃棄判定の責任が曖昧で滞留する
    classDef stall fill:#fff3bf,stroke:#e67700;
    class C1 stall;

    subgraph NOTE[ヒアリング論点]
        N1[保管棚の物理キャパは?]
        N2[再判定タイミングのトリガは?]
        N3[ITAR 廃棄の記録方式は?]
    end
